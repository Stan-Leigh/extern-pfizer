7', '8', 'Fizz', '10'] because 3, 6, and 9 are divisible by 3, so\n","`\"Fizz\"` is added for these numbers. The other numbers are not divisible by 3, so their string representations are added.\n","\n","Similarly, `fizz_buzz(5, 15, 5)` results in ['Fizz', '6', '7', '8', '9', 'Fizz', '11', '12', '13', '14', 'Fizz'] because 5, 10, and 15 are divisible by 5, so \"Fizz\" is added for these numbers. The other numbers are not divisible by 5, so their string representations are added.\n","<br>\n","<br>\n","### Write your code in the cell below:"],"metadata":{"id":"QUInqEwWCryU"}},{"cell_type":"code","source":["# This is the function that you need to populate with your code\n","def fizz_buzz(start, end, divisor):\n","    pass\n","\n","    ## Write your code here\n","    num = []\n","    for i in range(start, end + 1):\n","        if i % divisor == 0:\n","            num.append(\"Fizz\")\n","        else:\n","            num.append(str(i))\n","\n","    return num\n","\n","    ### Your code ends here"],"metadata":{"id":"pW9mtSdyCtJ3","executionInfo":{"status":"ok","timestamp":1781205472661,"user_tz":-60,"elapsed":19,"user":{"displayName":"Ugonna Nwani","userId":"07212607720272304506"}}},"execution_count":9,"outputs":[]},{"cell_type":"code","source":["# Example tests for your reference\n","print(fizz_buzz(1, 10, 3))\n","# Output: ['1', '2', 'Fizz', '4', '5', 'Fizz', '7', '8', 'Fizz', '10']\n","print(fizz_buzz(5, 15, 5))\n","# Output: ['Fizz', '6', '7', '8', '9', 'Fizz', '11', '12', '13', '14', 'Fizz']"],"metadata":{"id":"-ci-C8yXD0Gt","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1781205474503,"user_tz":-60,"elapsed":30,"user":{"displayName":"Ugonna Nwani","userId":"07212607720272304506"}},"outputId":"4554fbc5-a479-43a4-cbcc-f89c9d435c4d"},"execution_count":10,"outputs":[{"output_type":"stream","name":"stdout","text":["['1', '2', 'Fizz', '4', '5', 'Fizz', '7', '8', 'Fizz', '10']\n","['Fizz', '6', '7', '8', '9', 'Fizz', '11', '12', '1